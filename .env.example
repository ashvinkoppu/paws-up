# Supabase Configuration (required)
# Get these from your Supabase project: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (optional, for server-side JWT verification)
# Only needed in production/Vercel deployment
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI API Key (required for the FAQ chatbot feature)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
